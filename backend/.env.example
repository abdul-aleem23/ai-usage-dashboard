# App
APP_NAME=AI Usage Dashboard
ENVIRONMENT=development
DB_PATH=backend/data/aiusage.db
ADMIN_API_KEY=change-me-admin-key
ESP32_API_KEY=change-me-esp32-key
REFRESH_INTERVAL_MINUTES=10

# Codex / OpenAI subscription usage
# Choose any labels you want. Each label maps to CODEX_<NORMALIZED_LABEL>_AUTH_FILE.
CODEX_ACCOUNTS=main
CODEX_MAIN_AUTH_FILE=/secrets/codex-main-auth.json

# GitHub Copilot
COPILOT_TOKEN_FILE=/secrets/copilot-token.txt

# DeepSeek wallet balance
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BALANCE_TARGET_USD=5.00
DEEPSEEK_LOW_BALANCE_USD=1.00

# OpenCode is optional and disabled by default.
OPENCODE_ENABLED=false
OPENCODE_MODE=static
